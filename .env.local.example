# .env.local.example - Template untuk environment variables
# Copy file ini menjadi .env.local atau .env.development

# DATABASE (pilih salah satu)

# Opsi 1: Aiven (cloud)
DB_HOST=your_aiven_host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_secure_password
DB_NAME=defaultdb

# Opsi 2: Lokal (localhost)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=oscar_db

# AUTHENTICATION
JWT_SECRET=your_jwt_secret_min_32_characters

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000